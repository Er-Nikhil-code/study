# Production environment variables for Railway
# Copy this file and rename to .env.production, then fill in the values

# Database - Railway auto-provides this
# DATABASE_URL will be injected by Railway after adding PostgreSQL service
DATABASE_URL=postgresql://user:password@host:port/database

# Authentication
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7

# Email Service (Brevo)
BREVO_API_KEY=xkeysib-your-api-key-here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Your App Name
BREVO_OTP_TEMPLATE_ID=1
BREVO_PASSWORD_RESET_TEMPLATE_ID=2

# OTP Configuration
OTP_VALIDITY_MINUTES=10
OTP_MAX_ATTEMPTS=3
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60

# App Configuration
NODE_ENV=production
API_PORT=3001
APP_URL=https://your-railway-app.up.railway.app

# Optional: Cloudflare R2 (for file storage)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://cdn.yourdomain.com
